# Copy this file to .env and fill in your values. .env is gitignored.

# Chat provider: "ollama" (local, free, default), "gemini" (Google), or "deepseek".
BOOKCHECK_CHAT_PROVIDER=ollama

# Google Gemini — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek — get a key at https://platform.deepseek.com (OpenAI-compatible).
# Models: deepseek-v4-flash (fast/cheap) or deepseek-v4-pro (higher quality).
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Display name for light personalization (no real auth in local mode)
BOOKCHECK_USERNAME=Author

# Optional overrides
# BOOKCHECK_DB=data/book.db
# BOOKCHECK_REPORT=reports/report.md
# BOOKCHECK_CHAT_MODEL=qwen3:4b
